APP_ENV=development
SERVICE_NAME=kratos-agents-turbo
SERVICE_VERSION=0.3.0
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8001
REDIS_HOST_PORT=6380
GRAFANA_HOST_PORT=3001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-api-key
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-POOLER-HOST].pooler.supabase.com:5432/postgres
DATABASE_MIN_POOL_SIZE=1
DATABASE_MAX_POOL_SIZE=5
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_BACKEND_URL=redis://redis:6379/1
CELERY_TASK_QUEUE=legal-tasks
CELERY_DESPACHO_QUEUE=legal-despacho
CELERY_DECISAO_QUEUE=legal-decisao
CELERY_DEFAULT_WORKER_CONCURRENCY=1
CELERY_DESPACHO_WORKER_CONCURRENCY=4
CELERY_DECISAO_WORKER_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_VISIBILITY_TIMEOUT=7200
CELERY_RETRY_BACKOFF_BASE_SECONDS=30
CELERY_RETRY_BACKOFF_MAX_SECONDS=600
CELERY_DESPACHO_MAX_RETRIES=3
CELERY_DECISAO_MAX_RETRIES=2
CELERY_SENTENCA_MAX_RETRIES=1
DEFAULT_AGENT_ID=legal-document-agent
DEFAULT_TASK_TYPE=despacho
ALLOWED_TASK_TYPES=despacho,decisao,sentenca
DEFAULT_TASK_MESSAGE=Gere uma minuta simples, objetiva e juridicamente revisável.
MAX_UPLOAD_BYTES=10485760
MAX_BATCH_FILES=100
MAX_BATCH_BYTES=209715200
DEFAULT_DESPACHO_PRIORITY=9
DEFAULT_DECISAO_PRIORITY=6
DEFAULT_SENTENCA_PRIORITY=4
LOCAL_STORAGE_PATH=/app/runtime/uploads
OPS_PENDING_DISPATCH_AFTER_MINUTES=5
OPS_STUCK_TASK_AFTER_MINUTES=30
OTEL_ENABLED=false
OTEL_SERVICE_NAMESPACE=kratos
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
